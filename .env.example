# Nexo - variables de entorno base para desarrollo local

# Database
DATABASE_URL="postgresql://nexo:nexo_password@localhost:5432/nexo_db?schema=public"

# JWT
JWT_SECRET="cambiar-esto-en-produccion-usar-clave-segura-minimo-256bits"
JWT_EXPIRES="7d"
ENABLE_SWAGGER="true"

# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173"
APP_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
REQUEST_BODY_LIMIT="1mb"

# Frontend
VITE_API_URL="/api"

# Produccion de ejemplo
# FRONTEND_URL="https://tu-demo.vercel.app"
# CORS_ORIGINS="https://tu-demo.vercel.app,https://*.vercel.app"
